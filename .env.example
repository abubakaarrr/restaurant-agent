# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/restaurant_agent

# ── Anthropic (Claude — main LLM) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── OpenAI (embeddings only) ──────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxx

# ── LangSmith (optional tracing — very useful for debugging) ──
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxx
LANGCHAIN_PROJECT=restaurant-agent-poc

# ── Restaurant config ─────────────────────────────────────────
RESTAURANT_NAME=La Casa Restaurant
RESTAURANT_TIMEZONE=UTC

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
